// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  role          String    @default("AGENT")
  department    String?
  avatar        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workOrders    WorkOrder[] @relation("AssignedAgent")
  createdRecords ServiceRecord[] @relation("CreatedByAgent")
  consultations Consultation[] @relation("AgentConsultations")
  complaintHandlings Complaint[] @relation("HandlingAgent")
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  idCard       String?  @unique
  email        String?
  address      String?
  avatar       String?
  tags         String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  serviceRecords ServiceRecord[]
  consultations  Consultation[]
  complaints     Complaint[]
  workOrders     WorkOrder[]
  leases         Lease[]
}

model Property {
  id           String   @id @default(uuid())
  propertyNo   String   @unique
  title        String
  address      String
  type         String
  area         Float?
  rooms        Int?
  bathrooms    Int?
  floor        String?
  rentAmount   Float
  depositAmount Float?
  status       String   @default("AVAILABLE")
  description  String?
  images       String   @default("[]")
  amenities    String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leases       Lease[]
  consultations Consultation[]
  maintenanceRecords MaintenanceRecord[]
  complaints   Complaint[]
  workOrders   WorkOrder[]
}

model Lease {
  id            String   @id @default(uuid())
  leaseNo       String   @unique
  tenantId      String
  propertyId    String
  startDate     DateTime
  endDate       DateTime
  monthlyRent   Float
  depositAmount Float
  payCycle      String   @default("MONTHLY")
  status        String   @default("ACTIVE")
  signDate      DateTime?
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  property      Property @relation(fields: [propertyId], references: [id])
  payments      LeasePayment[]
}

model LeasePayment {
  id          String   @id @default(uuid())
  leaseId     String
  period      String
  amount      Float
  dueDate     DateTime
  paidDate    DateTime?
  status      String   @default("PENDING")
  paymentMethod String?
  remarks     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lease       Lease    @relation(fields: [leaseId], references: [id])
}

model MaintenanceRecord {
  id          String   @id @default(uuid())
  propertyId  String
  type        String
  description String
  status      String   @default("PENDING")
  startTime   DateTime?
  endTime     DateTime?
  cost        Float?
  contractor  String?
  remarks     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id])
}

model ServiceRecord {
  id            String        @id @default(uuid())
  tenantId      String
  type          String
  channel       String
  title         String
  content       String
  sourceId      String?
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  createdBy     Agent?        @relation("CreatedByAgent", fields: [createdById], references: [id])
  consultation  Consultation? @relation("ConsultationRecord")
  complaint     Complaint?    @relation("ComplaintRecord")
  workOrder     WorkOrder?    @relation("WorkOrderRecord")
}

model Consultation {
  id              String          @id @default(uuid())
  serviceRecordId String          @unique
  tenantId        String
  propertyId      String?
  agentId         String?
  category        String
  question        String
  answer          String?
  status          String          @default("OPEN")
  priority        String          @default("NORMAL")
  satisfaction    Int?
  resolvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  serviceRecord   ServiceRecord   @relation("ConsultationRecord", fields: [serviceRecordId], references: [id])
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  property        Property?       @relation(fields: [propertyId], references: [id])
  agent           Agent?          @relation("AgentConsultations", fields: [agentId], references: [id])
}

model Complaint {
  id                String          @id @default(uuid())
  serviceRecordId   String          @unique
  tenantId          String
  propertyId        String?
  handlingAgentId   String?
  category          String
  type              String          @default("INFORMAL")
  priority          String          @default("NORMAL")
  status            String          @default("RECEIVED")
  subject           String
  description       String
  responsibleParty  String?
  promisedDeadline  DateTime?
  isRepeat          Boolean         @default(false)
  relatedComplaintId String?
  satisfaction      Int?
  receivedAt        DateTime        @default(now())
  resolvedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  serviceRecord     ServiceRecord   @relation("ComplaintRecord", fields: [serviceRecordId], references: [id])
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  property          Property?       @relation(fields: [propertyId], references: [id])
  handlingAgent     Agent?          @relation("HandlingAgent", fields: [handlingAgentId], references: [id])
  relatedComplaint  Complaint?      @relation("RelatedComplaints", fields: [relatedComplaintId], references: [id])
  relatedComplaints Complaint[]     @relation("RelatedComplaints")
  workOrders        WorkOrder[]     @relation("ComplaintWorkOrders")
}

model WorkOrder {
  id                 String          @id @default(uuid())
  serviceRecordId    String          @unique
  tenantId           String
  complaintId        String?
  propertyId         String?
  assignedAgentId    String?
  title              String
  description        String
  type               String
  category           String
  priority           String          @default("NORMAL")
  status             String          @default("CREATED")
  progress           Int             @default(0)
  promisedDeadline   DateTime?
  actualCompletion   DateTime?
  satisfaction       Int?
  feedbackResult     String?
  followUpRequired   Boolean         @default(false)
  followUpDate       DateTime?
  followUpNotes      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  serviceRecord      ServiceRecord   @relation("WorkOrderRecord", fields: [serviceRecordId], references: [id])
  tenant             Tenant          @relation(fields: [tenantId], references: [id])
  complaint          Complaint?      @relation("ComplaintWorkOrders", fields: [complaintId], references: [id])
  property           Property?       @relation(fields: [propertyId], references: [id])
  assignedAgent      Agent?          @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  statusLogs         WorkOrderStatusLog[]
}

model WorkOrderStatusLog {
  id          String          @id @default(uuid())
  workOrderId String
  fromStatus  String?
  toStatus    String
  progress    Int?
  remarks     String?
  operatorId  String?
  createdAt   DateTime        @default(now())

  workOrder   WorkOrder       @relation(fields: [workOrderId], references: [id])
}

model FAQCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      FAQCategory?  @relation("ParentChild", fields: [parentId], references: [id])
  children    FAQCategory[] @relation("ParentChild")
}
